# =============================================================================
# Docker Compose Environment Variables (used by docker-compose.prod.yml)
# =============================================================================
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_secure_postgres_password
API_GATEWAY_PORT=8080
GITHUB_REPOSITORY_OWNER=your_github_username

# =============================================================================
# Auth Service Environment Variables
# File: services/auth-service/.env
# =============================================================================
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432
# POSTGRES_USER=your_postgres_user
# POSTGRES_PASSWORD=your_secure_postgres_password
# POSTGRES_DB=lifeos_auth
# DATABASE_URL=postgresql://your_postgres_user:your_secure_postgres_password@postgres:5432/lifeos_auth

# JWT_SECRET=your_very_long_and_secure_jwt_secret_key_min_32_chars
# JWT_EXPIRATION=15m
# PORT=3000
# NODE_ENV=production

# =============================================================================
# Knowledge Service Environment Variables
# File: services/knowledge-service/.env
# =============================================================================
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432
# POSTGRES_USER=your_postgres_user
# POSTGRES_PASSWORD=your_secure_postgres_password
# POSTGRES_DB=lifeos_knowledge
# DATABASE_URL=postgresql://your_postgres_user:your_secure_postgres_password@postgres:5432/lifeos_knowledge

# JWT_SECRET=your_very_long_and_secure_jwt_secret_key_min_32_chars
# JWT_EXPIRATION=15m
# PORT=3002
# NODE_ENV=production
# UPLOAD_DIR=./uploads
# MAX_FILE_SIZE=10485760
