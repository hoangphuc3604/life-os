{
	"info": {
		"_postman_id": "c62f22b8-9336-4074-a8eb-9d10ac6ea7ae",
		"name": "LifeOS API Gateway",
		"description": "Collection để test API của dự án LifeOS sau khi tích hợp Nginx API Gateway. Bao gồm các tính năng tự động lưu Access Token và Refresh Token vào biến môi trường.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth Service",
			"item": [
				{
					"name": "1. Register",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\r\n    \"username\": \"testuser1\",\r\n    \"email\": \"testuser1@example.com\",\r\n    \"password\": \"password123\"\r\n}"
						},
						"url": {
							"raw": "{{BASE_URL}}/api/auth/register",
							"host": [
								"{{BASE_URL}}"
							],
							"path": [
								"api",
								"auth",
								"register"
							]
						}
					},
					"response": []
				},
				{
					"name": "2. Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.access_token) {",
									"    pm.environment.set(\"ACCESS_TOKEN\", jsonData.access_token);",
									"}",
									"if (jsonData.refresh_token) {",
									"    pm.environment.set(\"REFRESH_TOKEN\", jsonData.refresh_token);",
									"}",
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\r\n    \"username\": \"testuser1\",\r\n    \"password\": \"password123\"\r\n}"
						},
						"url": {
							"raw": "{{BASE_URL}}/api/auth/login",
							"host": [
								"{{BASE_URL}}"
							],
							"path": [
								"api",
								"auth",
								"login"
							]
						}
					},
					"response": []
				},
				{
					"name": "3. Get Profile",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{ACCESS_TOKEN}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{BASE_URL}}/api/auth/profile",
							"host": [
								"{{BASE_URL}}"
							],
							"path": [
								"api",
								"auth",
								"profile"
							]
						}
					},
					"response": []
				},
				{
					"name": "4. Refresh Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.access_token) {",
									"    pm.environment.set(\"ACCESS_TOKEN\", jsonData.access_token);",
									"}",
									"if (jsonData.refresh_token) {",
									"    pm.environment.set(\"REFRESH_TOKEN\", jsonData.refresh_token);",
									"}",
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\r\n    \"refresh_token\": \"{{REFRESH_TOKEN}}\"\r\n}"
						},
						"url": {
							"raw": "{{BASE_URL}}/api/auth/refresh",
							"host": [
								"{{BASE_URL}}"
							],
							"path": [
								"api",
								"auth",
								"refresh"
							]
						}
					},
					"response": []
				},
				{
					"name": "5. Logout",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201 or 200\", function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
									"    pm.environment.unset(\"ACCESS_TOKEN\");",
									"    pm.environment.unset(\"REFRESH_TOKEN\");",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\r\n    \"refresh_token\": \"{{REFRESH_TOKEN}}\"\r\n}"
						},
						"url": {
							"raw": "{{BASE_URL}}/api/auth/logout",
							"host": [
								"{{BASE_URL}}"
							],
							"path": [
								"api",
								"auth",
								"logout"
							]
						}
					},
					"response": []
				}
			],
			"description": "APIs liên quan đến việc xác thực người dùng."
		},
		{
			"name": "Protected Services (via Gateway)",
			"item": [
				{
					"name": "Test Protected Endpoint",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{ACCESS_TOKEN}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{BASE_URL}}/api/protected/",
							"host": [
								"{{BASE_URL}}"
							],
							"path": [
								"api",
								"protected",
								""
							]
						},
						"description": "Thử nghiệm Identity Propagation. Nếu Header Authorization được gửi đi với Access Token hợp lệ, bạn sẽ thấy X-User-Id trả về trong JSON thông qua cổng Gateway."
					},
					"response": []
				}
			]
		}
	],
	"variable": [
		{
			"key": "BASE_URL",
			"value": "http://localhost:8080",
			"type": "string"
		}
	]
}
